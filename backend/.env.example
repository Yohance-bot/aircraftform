# Copy this file to .env and fill in real values for local development.

# Leave unset to use the local SQLite file `registrations.db`.
# For Postgres use the standard SQLAlchemy URL, e.g.
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname
DATABASE_URL=

# Any shared secret string. The admin dashboard sends this in the
# `X-Admin-Key` header to fetch registrations.
ADMIN_KEY=letsfly
